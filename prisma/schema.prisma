generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  WAITER
  CASHIER
}

enum TableShape {
  RECTANGLE
  CIRCLE
  SQUARE
}

enum SessionStatus {
  OPEN
  WAITING_FOOD
  WAITING_BILL
  CLOSED
}

enum OrderStatus {
  DRAFT
  SENT
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  taxId     String?  @map("tax_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users      User[]
  floorPlans FloorPlan[]
  tables     RestaurantTable[]
  categories Category[]
  products   Product[]
  sessions   TableSession[]
  orders     Order[]
  bills      Bill[]

  @@map("restaurants")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  pin          String?
  role         Role     @default(WAITER)
  active       Boolean  @default(true)
  restaurantId String   @map("restaurant_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id])
  sessions   TableSession[]
  orders     Order[]

  @@map("users")
}

model FloorPlan {
  id           String   @id @default(cuid())
  name         String
  width        Int      @default(1200)
  height       Int      @default(800)
  restaurantId String   @map("restaurant_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant        @relation(fields: [restaurantId], references: [id])
  tables     RestaurantTable[]

  @@map("floor_plans")
}

model RestaurantTable {
  id           String     @id @default(cuid())
  label        String
  x            Float      @default(0)
  y            Float      @default(0)
  width        Float      @default(80)
  height       Float      @default(80)
  rotation     Float      @default(0)
  shape        TableShape @default(RECTANGLE)
  seats        Int        @default(4)
  floorPlanId  String     @map("floor_plan_id")
  restaurantId String     @map("restaurant_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  floorPlan  FloorPlan      @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  restaurant Restaurant     @relation(fields: [restaurantId], references: [id])
  sessions   TableSession[]

  @@map("restaurant_tables")
}

model TableSession {
  id           String        @id @default(cuid())
  tableId      String        @map("table_id")
  waiterId     String        @map("waiter_id")
  restaurantId String        @map("restaurant_id")
  guests       Int           @default(1)
  status       SessionStatus @default(OPEN)
  openedAt     DateTime      @default(now()) @map("opened_at")
  closedAt     DateTime?     @map("closed_at")

  table      RestaurantTable @relation(fields: [tableId], references: [id])
  waiter     User            @relation(fields: [waiterId], references: [id])
  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  orders     Order[]
  bills      Bill[]

  @@map("table_sessions")
}

model Category {
  id           String   @id @default(cuid())
  name         String
  sortOrder    Int      @default(0) @map("sort_order")
  restaurantId String   @map("restaurant_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  products   Product[]

  @@map("categories")
}

model Product {
  id              String   @id @default(cuid())
  name            String
  description     String?
  price           Float
  imageUrl        String?  @map("image_url")
  available       Boolean  @default(true)
  printInKitchen  Boolean  @default(true) @map("print_in_kitchen")
  categoryId      String   @map("category_id")
  restaurantId    String   @map("restaurant_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  category   Category    @relation(fields: [categoryId], references: [id])
  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  Int         @map("order_number")
  sessionId    String      @map("session_id")
  waiterId     String      @map("waiter_id")
  restaurantId String      @map("restaurant_id")
  status       OrderStatus @default(DRAFT)
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  session    TableSession @relation(fields: [sessionId], references: [id])
  waiter     User         @relation(fields: [waiterId], references: [id])
  restaurant Restaurant   @relation(fields: [restaurantId], references: [id])
  items      OrderItem[]
  billItems  BillItem[]

  @@map("orders")
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String          @map("order_id")
  productId String          @map("product_id")
  quantity  Int             @default(1)
  unitPrice Float           @map("unit_price")
  notes     String?
  status    OrderItemStatus @default(PENDING)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Bill {
  id            String        @id @default(cuid())
  sessionId     String        @map("session_id")
  restaurantId  String        @map("restaurant_id")
  subtotal      Float         @default(0)
  tax           Float         @default(0)
  total         Float         @default(0)
  paymentMethod PaymentMethod?  @map("payment_method")
  paid          Boolean       @default(false)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  session    TableSession @relation(fields: [sessionId], references: [id])
  restaurant Restaurant   @relation(fields: [restaurantId], references: [id])
  items      BillItem[]

  @@map("bills")
}

model BillItem {
  id        String @id @default(cuid())
  billId    String @map("bill_id")
  orderId   String @map("order_id")
  productId String @map("product_id")
  quantity  Int    @default(1)
  unitPrice Float  @map("unit_price")
  total     Float  @default(0)

  bill  Bill  @relation(fields: [billId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id])

  @@map("bill_items")
}
